import { LineEdit, ScrollView } from "std-widgets.slint";
import { CheckBoxSlot } from "widgets.slint";
import { TitleBar, SettingsDropdown } from "window_chrome.slint";

export struct ProcessRow {
    process: string,
    pid: string,
    icon: image,
    show-icon: bool,
    use-computer-icon: bool,
    expandable: bool,
    expanded: bool,
    dl_speed: string,
    ul_speed: string,
    limit_dl: bool,
    dl_limit: string,
    dl_limit_edit: string,
    limit_ul: bool,
    ul_limit: string,
    ul_limit_edit: string,
    block: bool,
    adaptive: bool,
    is_global: bool,
    is_group: bool,
    depth: int,
}

export struct ConnectionRow {
    key: string,
    label: string,
    detail: string,
    disconnectable: bool,
}

component ExpandChevron inherits Rectangle {
    in property <bool> expanded;
    in property <color> stroke-color: #28313d;
    background: transparent;

    Path {
        width: 8px;
        height: 8px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.stroke-color;
        stroke-width: 1.2px;
        commands: root.expanded ? "M 1 3 L 4 6 L 7 3" : "M 3 1 L 6 4 L 3 7";
    }
}

component ComputerIcon inherits Rectangle {
    in property <color> stroke-color: #24303f;
    width: 16px;
    height: 16px;
    background: transparent;

    Path {
        width: 14px;
        height: 11px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.stroke-color;
        stroke-width: 1.1px;
        commands: "M 1 1 L 13 1 L 13 7 L 9 7 L 8 10 L 6 10 L 5 7 L 1 7 Z";
    }
}

component ExpandSlot inherits Rectangle {
    in property <bool> expandable;
    in property <bool> expanded;
    in property <color> stroke-color: #28313d;
    width: 12px;
    height: 16px;

    if root.expandable : ExpandChevron {
        width: 12px;
        height: 12px;
        y: (parent.height - self.height) / 2;
        expanded: root.expanded;
        stroke-color: root.stroke-color;
    }
}

component IconSlot inherits Rectangle {
    in property <image> icon;
    in property <bool> show-icon;
    in property <bool> use-computer-icon;
    in property <color> stroke-color: #28313d;
    width: 16px;
    height: 16px;

    if root.use-computer-icon : ComputerIcon {
        width: 16px;
        height: 16px;
        stroke-color: root.stroke-color;
    }

    if root.show-icon : Image {
        source: root.icon;
        width: 16px;
        height: 16px;
        image-fit: contain;
    }
}

// Slint 1.16: HorizontalLayout.alignment is horizontal (main axis).
// Nest VerticalLayout spacers for vertical center + HorizontalLayout start for left align.
component ProcessCell inherits Rectangle {
    in property <string> text;
    in property <image> icon;
    in property <bool> show-icon;
    in property <bool> use-computer-icon;
    in property <int> depth;
    in property <bool> expandable;
    in property <bool> expanded;
    in property <length> row-height: 32px;
    in property <color> foreground: #24303f;
    in property <bool> strong: false;
    width: 280px;
    height: root.row-height;

    VerticalLayout {
        width: parent.width;
        height: parent.height;

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            width: parent.width;
            padding-right: 4px;
            spacing: 6px;

            ExpandSlot {
                expandable: root.expandable;
                expanded: root.expanded;
                stroke-color: root.foreground;
            }

            IconSlot {
                icon: root.icon;
                show-icon: root.show-icon;
                use-computer-icon: root.use-computer-icon;
                stroke-color: root.foreground;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
                spacing: 0px;

                Rectangle {
                    width: root.depth * 16px;
                }

                Text {
                    horizontal-stretch: 1;
                    height: 16px;
                    text: root.text;
                    color: root.foreground;
                    font-size: 12px;
                    font-weight: root.strong ? 600 : 400;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }
    }
}

component Cell inherits Rectangle {
    in property <string> text;
    in property <length> cell-width: 80px;
    in property <color> foreground: #24303f;
    in property <bool> strong: false;
    width: root.cell-width;
    height: 32px;

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: root.foreground;
        font-size: 12px;
        font-weight: root.strong ? 600 : 400;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
}

component HeaderCell inherits Rectangle {
    in property <string> text;
    in property <length> cell-width: 80px;
    background: transparent;
    width: root.cell-width;
    height: 36px;

    Text {
        text: root.text;
        width: parent.width;
        height: parent.height;
        color: #33465f;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
        horizontal-alignment: left;
        overflow: elide;
    }
}

component CheckCell inherits Rectangle {
    in property <bool> checked;
    in property <length> cell-width: 70px;
    in property <bool> enabled: true;
    callback toggled(bool);
    width: root.cell-width;
    height: 32px;

    CheckBoxSlot {
        checked: root.checked;
        enabled: root.enabled;
        x: 0px;
        y: (parent.height - self.height) / 2;
        toggled(value) => {
            root.toggled(value);
        }
    }
}

component LimitDisplayCell inherits Rectangle {
    in property <bool> checked;
    in property <string> text;
    in property <string> edit-value;
    in property <length> cell-width: 132px;
    in property <bool> highlighted: false;
    callback toggled(bool);
    callback limit-submitted(string);
    callback focus-changed(bool);
    width: root.cell-width;
    height: 32px;

    cell-shield := TouchArea {
        width: parent.width;
        height: parent.height;
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            width: parent.width;
            spacing: 0px;

            Rectangle {
                horizontal-stretch: 1;
            }

            HorizontalLayout {
                spacing: 8px;

                CheckBoxSlot {
                    slot-height: 26px;
                    checked: root.checked;
                    toggled(value) => {
                        root.toggled(value);
                    }
                }

                Rectangle {
                    width: root.cell-width - 30px;
                    height: 26px;
                    background: root.checked ? (root.highlighted ? #244562 : #e8f2ff) : transparent;
                    border-color: root.checked ? #4a8fc8 : transparent;
                    border-width: 1px;
                    border-radius: 4px;

                    if !root.checked: Text {
                        text: root.text;
                        font-size: 12px;
                        color: root.highlighted ? #edf6ff : #65758b;
                        x: 7px;
                        width: parent.width - 14px;
                        height: parent.height;
                        vertical-alignment: center;
                        horizontal-alignment: left;
                        overflow: elide;
                    }

                    if root.checked: TextInput {
                        text: root.edit-value;
                        x: 7px;
                        y: 1px;
                        width: parent.width - 14px;
                        height: parent.height - 2px;
                        font-size: 12px;
                        color: root.highlighted ? #edf6ff : #23435f;
                        single-line: true;
                        vertical-alignment: center;
                        accepted => {
                            root.limit-submitted(self.text);
                            self.clear-focus();
                        }
                        changed has-focus => {
                            if (!self.has-focus) {
                                root.limit-submitted(self.text);
                            }
                            root.focus-changed(self.has-focus);
                        }
                    }
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }
    }
}

component InfoPair inherits Rectangle {
    in property <string> label;
    in property <string> value;
    height: 28px;

    VerticalLayout {
        spacing: 1px;

        Text {
            text: root.label;
            color: #65758b;
            font-size: 11px;
            font-weight: 600;
        }

        Text {
            text: root.value;
            color: #24303f;
            font-size: 13px;
            font-weight: 600;
            overflow: elide;
        }
    }
}

component SidebarCheck inherits Rectangle {
    in property <string> text;
    in property <bool> checked;
    callback toggled(bool);
    height: 28px;

    VerticalLayout {
        height: parent.height;

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 6px;

            CheckBoxSlot {
                checked: root.checked;
                toggled(value) => {
                    root.toggled(value);
                }
            }

            Text {
                text: root.text;
                height: 18px;
                color: #24303f;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }
    }
}

component SidebarLabel inherits Rectangle {
    in property <string> text;
    height: 18px;

    Text {
        text: root.text;
        color: #52647a;
        font-size: 11px;
        font-weight: 700;
        vertical-alignment: center;
    }
}

component SidebarActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();
    height: 26px;
    min-width: 72px;
    background: enabled && action-hover.has-hover ? #d9e8f7 : (enabled ? #edf4fb : #eef1f5);
    border-radius: 4px;
    border-color: enabled ? #b7cde2 : #d5dbe3;
    border-width: 1px;

    action-hover := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        color: root.enabled ? #1f4f78 : #9aa6b5;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component ConnectionRowItem inherits Rectangle {
    in property <ConnectionRow> connection;
    callback disconnect-requested(string);
    height: 42px;
    background: transparent;

    VerticalLayout {
        spacing: 2px;
        padding-top: 2px;
        padding-bottom: 2px;

        HorizontalLayout {
            spacing: 6px;

            Text {
                text: root.connection.label;
                color: #172638;
                font-size: 12px;
                font-weight: 600;
                overflow: elide;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }

            SidebarActionButton {
                text: "Disconnect";
                enabled: root.connection.disconnectable;
                clicked => {
                    root.disconnect-requested(root.connection.key);
                }
            }
        }

        Text {
            text: root.connection.detail;
            color: #65758b;
            font-size: 10px;
            overflow: elide;
        }
    }
}

component SidebarTabButton inherits Rectangle {
    in property <string> text;
    in property <bool> active;
    callback clicked();
    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.active ? #c5d5e6 : transparent;
    background:
        root.active
            ? #ffffff
            : (tab-hit.pressed
                ? #d5dde8
                : (tab-hit.has-hover ? #dfe7f1 : transparent));

    tab-hit := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        color:
            root.active
                ? #1a4f78
                : (tab-hit.has-hover ? #364a61 : #6b7c90);
        font-size: 12px;
        font-weight: root.active ? 700 : 600;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
        overflow: elide;
    }
}

component SidebarTabBar inherits Rectangle {
    in property <int> active-index;
    in property <string> details-label: "Details";
    in property <string> connections-label: "Connections";
    in property <length> tab-slot-width;
    callback tab-selected(int);
    height: 36px;
    background: #e8eef5;
    border-radius: 8px;
    border-color: #d2dbe7;
    border-width: 1px;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding: 3px;
        spacing: 2px;

        SidebarTabButton {
            width: root.tab-slot-width;
            text: root.details-label;
            active: root.active-index == 0;
            clicked => {
                root.tab-selected(0);
            }
        }

        SidebarTabButton {
            width: root.tab-slot-width;
            text: root.connections-label;
            active: root.active-index == 1;
            clicked => {
                root.tab-selected(1);
            }
        }
    }
}

component SidebarInput inherits Rectangle {
    in property <string> label;
    in property <string> value;
    callback submitted(string);
    callback focus-changed(bool);
    height: 48px;

    VerticalLayout {
        spacing: 5px;

        Text {
            text: root.label;
            color: #65758b;
            font-size: 11px;
            font-weight: 700;
        }

        Rectangle {
            height: 28px;
            width: parent.width;
            background: #ffffff;
            border-color: input.has-focus ? #4a8fc8 : #cbd7e4;
            border-width: 1px;
            border-radius: 4px;

            input := TextInput {
                text: root.value;
                x: 8px;
                y: 1px;
                width: parent.width - 16px;
                height: parent.height - 2px;
                font-size: 13px;
                color: #172638;
                single-line: true;
                vertical-alignment: center;
                accepted => {
                    root.submitted(self.text);
                    self.clear-focus();
                }
                changed has-focus => {
                    if (!self.has-focus) {
                        root.submitted(self.text);
                    }
                    root.focus-changed(self.has-focus);
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    preferred-width: 1180px;
    preferred-height: 700px;
    min-width: 900px;
    min-height: 500px;
    title: "FlowBrake";
    no-frame: true;
    resize-border-width: 4px;

    in property <[ProcessRow]> rows;
    in property <string> status-text: "Interceptor stopped";
    in property <bool> running: false;
    in property <int> selected-row: -1;
    in property <bool> sidebar-open: false;
    in property <string> selected-title: "";
    in property <string> selected-kind: "";
    in property <string> selected-pid: "";
    in property <string> selected-pids: "";
    in property <string> selected-dl-speed: "";
    in property <string> selected-ul-speed: "";
    in property <bool> selected-limit-dl: false;
    in property <string> selected-dl-limit: "";
    in property <bool> selected-limit-ul: false;
    in property <string> selected-ul-limit: "";
    in property <bool> selected-block: false;
    in property <bool> selected-adaptive: false;
    in property <bool> selected-show-connections: false;
    in property <string> selected-connections-summary: "";
    in property <[ConnectionRow]> selected-connections: [];
    in property <bool> selected-can-disconnect-all: false;
    in property <string> selected-connections-tab-title: "Connections";
    in-out property <int> selected-sidebar-tab: 0;
    in property <string> summary-throughput: "DL 0 b/s / UL 0 b/s";
    in property <string> summary-global-limit: "DL Off / UL Off";
    in property <string> summary-process-limits: "0";
    in property <string> summary-blocked: "0";
    in property <string> summary-adaptive: "0";
    in property <bool> window-maximized: false;
    in property <bool> speed-unit-bits: true;
    in property <bool> ipv6-enabled: true;
    in-out property <bool> settings-open: false;

    property <length> settings-menu-x: root.width - 358px;

    property <string> dl-limit-header: root.speed-unit-bits ? "DL Limit Kb/s" : "DL Limit KB/s";
    property <string> ul-limit-header: root.speed-unit-bits ? "UL Limit Kb/s" : "UL Limit KB/s";
    property <string> dl-limit-label: root.speed-unit-bits ? "Download Kb/s" : "Download KB/s";
    property <string> ul-limit-label: root.speed-unit-bits ? "Upload Kb/s" : "Upload KB/s";
    property <length> sidebar-content-width: 268px;
    property <length> sidebar-tab-slot-width: 130px;
    property <length> sidebar-details-bottom-padding: 24px;
    property <length> sidebar-details-scroll-height:
        (root.selected-show-connections ? 470px : 436px) + root.sidebar-details-bottom-padding;
    property <length> sidebar-connections-viewport-height:
        24px + root.selected-connections.length * 42px + root.sidebar-details-bottom-padding;
    // Global row is 36px; all other rows are 32px.
    property <length> table-viewport-height: root.rows.length > 0 ? root.rows.length * 32px + 4px : 0px;

    callback window-drag-requested();
    callback window-minimize-requested();
    callback window-maximize-toggle-requested();
    callback window-close-requested();
    callback row-clicked(int);
    callback selection-cleared();
    callback bool-rule-edited(int, string, bool);
    callback row-limit-submitted(int, string, string);
    callback row-limit-focus-changed(bool);
    callback selected-limit-submitted(string, string);
    callback selected-bool-rule-edited(string, bool);
    callback sidebar-focus-changed(bool);
    callback speed-unit-bits-changed(bool);
    callback ipv6-enabled-changed(bool);
    callback connection-disconnect-requested(string);
    callback disconnect-all-tcp-requested();

    // Transparent window background lets DWM rounded corners show through; the
    // clipped chrome shell paints the visible surface.
    background: transparent;
    property <length> chrome-radius: root.window-maximized ? 0px : 8px;

    function clear-active-inputs() {
        focus-sink.focus();
    }

    focus-sink := FocusScope {
        x: 0px;
        y: 0px;
        width: 0px;
        height: 0px;
    }

    chrome-shell := Rectangle {
        width: 100%;
        height: 100%;
        background: #f6f8fb;
        border-radius: root.chrome-radius;
        clip: true;
        border-color: #dfe6ef;
        border-width: root.window-maximized ? 0px : 1px;

        VerticalLayout {
        spacing: 0px;

        TitleBar {
            title: "FlowBrake";
            maximized: root.window-maximized;
            speed-unit-bits: root.speed-unit-bits;
            settings-open <=> root.settings-open;
            drag-requested => {
                root.window-drag-requested();
            }
            minimize-requested => {
                root.window-minimize-requested();
            }
            maximize-toggle-requested => {
                root.window-maximize-toggle-requested();
            }
            close-requested => {
                root.window-close-requested();
            }
            speed-unit-bits-changed(bits) => {
                root.clear-active-inputs();
                root.speed-unit-bits-changed(bits);
            }
        }

        Rectangle {
            height: 36px;
            background: #dfe8f2;
            border-color: #c8d4e2;
            border-width: 1px;

            TouchArea {
                clicked => {
                    root.clear-active-inputs();
                    root.selection-cleared();
                }
            }

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;

                HeaderCell { text: "Process"; cell-width: 280px; }
                HeaderCell { text: "PID"; cell-width: 64px; }
                HeaderCell { text: "DL Speed"; cell-width: 104px; }
                HeaderCell { text: "UL Speed"; cell-width: 104px; }
                HeaderCell { text: root.dl-limit-header; cell-width: 132px; }
                HeaderCell { text: root.ul-limit-header; cell-width: 132px; }
                HeaderCell { text: "Block"; cell-width: 64px; }
                HeaderCell { text: "Adaptive"; cell-width: 82px; }
            }
        }

        HorizontalLayout {
            spacing: 0px;
            vertical-stretch: 1;

            Rectangle {
                vertical-stretch: 1;
                horizontal-stretch: 1;
                clip: true;

                ScrollView {
                    width: parent.width;
                    height: parent.height;
                    viewport-width: parent.width;
                    viewport-height: root.table-viewport-height;

                    VerticalLayout {
                        spacing: 0px;

                        for row[index] in root.rows: Rectangle {
                            height: row.is_global ? 36px : 32px;
                            background:
                                index == root.selected-row
                                    ? (row.is_global ? #b8d9f5 : #c5daf4)
                                    : row-hit.has-hover
                                        ? (row.is_global ? #173f61 : (row.is_group ? #dde7f3 : #edf2f8))
                                        : (row.is_global ? #12304a : (row.is_group ? #e7eef7 : #f8fafc));

                            row-hit := TouchArea {
                                width: parent.width;
                                height: parent.height;
                                clicked => {
                                    root.clear-active-inputs();
                                    root.row-clicked(index);
                                }
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 8px;
                                alignment: center;

                                ProcessCell {
                                    text: row.process;
                                    icon: row.icon;
                                    show-icon: row.show-icon;
                                    use-computer-icon: row.use-computer-icon;
                                    depth: row.depth;
                                    expandable: row.expandable;
                                    expanded: row.expanded;
                                    row-height: row.is_global ? 36px : 32px;
                                    foreground: row.is_global && index != root.selected-row ? white : #24303f;
                                    strong: row.is_global || row.is_group;
                                }
                                Cell { text: row.pid; cell-width: 64px; foreground: row.is_global && index != root.selected-row ? white : #596579; }
                                Cell { text: row.dl_speed; cell-width: 104px; foreground: row.is_global && index != root.selected-row ? white : #167454; }
                                Cell { text: row.ul_speed; cell-width: 104px; foreground: row.is_global && index != root.selected-row ? white : #7b4f12; }
                                LimitDisplayCell {
                                    checked: row.limit_dl;
                                    text: row.dl_limit;
                                    edit-value: row.dl_limit_edit;
                                    cell-width: 132px;
                                    highlighted: row.is_global && index != root.selected-row;
                                    toggled(value) => { root.bool-rule-edited(index, "limit_dl", value); }
                                    limit-submitted(value) => { root.row-limit-submitted(index, "dl", value); }
                                    focus-changed(focused) => { root.row-limit-focus-changed(focused); }
                                }
                                LimitDisplayCell {
                                    checked: row.limit_ul;
                                    text: row.ul_limit;
                                    edit-value: row.ul_limit_edit;
                                    cell-width: 132px;
                                    highlighted: row.is_global && index != root.selected-row;
                                    toggled(value) => { root.bool-rule-edited(index, "limit_ul", value); }
                                    limit-submitted(value) => { root.row-limit-submitted(index, "ul", value); }
                                    focus-changed(focused) => { root.row-limit-focus-changed(focused); }
                                }
                                CheckCell {
                                    checked: row.block;
                                    cell-width: 64px;
                                    toggled(value) => { root.clear-active-inputs(); root.bool-rule-edited(index, "block", value); }
                                }
                                CheckCell {
                                    checked: row.adaptive;
                                    cell-width: 82px;
                                    toggled(value) => { root.clear-active-inputs(); root.bool-rule-edited(index, "adaptive", value); }
                                }
                            }
                        }
                    }
                }
            }

            if root.sidebar-open: Rectangle {
                width: 300px;
                vertical-stretch: 1;
                background: #ffffff;
                border-color: #d7e0eb;
                border-width: 1px;
                clip: true;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding-left: 16px;
                    padding-right: 16px;
                    padding-top: 10px;
                    padding-bottom: 10px;
                    spacing: 6px;

                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;

                        Text {
                            text: root.selected-title;
                            color: #172638;
                            font-size: 17px;
                            font-weight: 700;
                            overflow: elide;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            background: close-hover.has-hover ? #e9eef5 : transparent;
                            border-radius: 4px;

                            close-hover := TouchArea {
                                clicked => {
                                    root.clear-active-inputs();
                                    root.selection-cleared();
                                }
                            }

                            Text {
                                text: "X";
                                color: #52647a;
                                font-size: 13px;
                                font-weight: 700;
                                width: parent.width;
                                height: parent.height;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    Rectangle { height: 1px; background: #e2e8f0; }

                    if root.selected-show-connections: SidebarTabBar {
                        width: root.sidebar-content-width;
                        tab-slot-width: root.sidebar-tab-slot-width;
                        active-index: root.selected-sidebar-tab;
                        connections-label: root.selected-connections-tab-title;
                        tab-selected(index) => {
                            root.selected-sidebar-tab = index;
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        width: root.sidebar-content-width;
                        clip: true;

                        if !root.selected-show-connections || root.selected-sidebar-tab == 0: ScrollView {
                            width: root.sidebar-content-width;
                            height: parent.height;
                            viewport-width: root.sidebar-content-width;
                            viewport-height: root.sidebar-details-scroll-height;

                            VerticalLayout {
                                width: root.sidebar-content-width;
                                spacing: 6px;

                                InfoPair { label: "Row Type"; value: root.selected-kind; }
                                InfoPair { label: "PID"; value: root.selected-pid; }
                                InfoPair { label: "PIDs"; value: root.selected-pids; }
                                InfoPair { label: "Download"; value: root.selected-dl-speed; }
                                InfoPair { label: "Upload"; value: root.selected-ul-speed; }

                                Rectangle { height: 1px; background: #e2e8f0; }

                                SidebarLabel { text: "LIMITS"; }

                                SidebarCheck {
                                    text: "Limit download";
                                    checked: root.selected-limit-dl;
                                    toggled(value) => { root.selected-bool-rule-edited("limit_dl", value); }
                                }

                                SidebarInput {
                                    label: root.dl-limit-label;
                                    value: root.selected-dl-limit;
                                    submitted(value) => { root.selected-limit-submitted("dl", value); }
                                    focus-changed(value) => { root.sidebar-focus-changed(value); }
                                }

                                SidebarCheck {
                                    text: "Limit upload";
                                    checked: root.selected-limit-ul;
                                    toggled(value) => { root.selected-bool-rule-edited("limit_ul", value); }
                                }

                                SidebarInput {
                                    label: root.ul-limit-label;
                                    value: root.selected-ul-limit;
                                    submitted(value) => { root.selected-limit-submitted("ul", value); }
                                    focus-changed(value) => { root.sidebar-focus-changed(value); }
                                }

                                Rectangle { height: 1px; background: #e2e8f0; }

                                SidebarLabel { text: "ACTIONS"; }

                                HorizontalLayout {
                                    width: root.sidebar-content-width;
                                    height: 28px;
                                    spacing: 8px;

                                    SidebarCheck {
                                        horizontal-stretch: 1;
                                        text: "Block traffic";
                                        checked: root.selected-block;
                                        toggled(value) => { root.selected-bool-rule-edited("block", value); }
                                    }

                                    SidebarCheck {
                                        horizontal-stretch: 1;
                                        text: "Adaptive";
                                        checked: root.selected-adaptive;
                                        toggled(value) => { root.selected-bool-rule-edited("adaptive", value); }
                                    }
                                }

                                if root.selected-show-connections: Rectangle {
                                    height: 1px;
                                    background: #e2e8f0;
                                }

                                if root.selected-show-connections: SidebarActionButton {
                                    width: root.sidebar-content-width;
                                    text: "Disconnect all";
                                    enabled: root.selected-can-disconnect-all;
                                    clicked => {
                                        root.disconnect-all-tcp-requested();
                                    }
                                }

                                Rectangle {
                                    height: root.sidebar-details-bottom-padding;
                                    background: transparent;
                                }
                            }
                        }

                        if root.selected-show-connections && root.selected-sidebar-tab == 1: ScrollView {
                            width: root.sidebar-content-width;
                            height: parent.height;
                            viewport-width: root.sidebar-content-width;
                            viewport-height: root.sidebar-connections-viewport-height;

                            VerticalLayout {
                                width: root.sidebar-content-width;
                                spacing: 0px;

                                Text {
                                    text: root.selected-connections-summary;
                                    color: #65758b;
                                    font-size: 11px;
                                    height: 20px;
                                    overflow: elide;
                                }

                                for conn in root.selected-connections: ConnectionRowItem {
                                    connection: conn;
                                    disconnect-requested(key) => {
                                        root.connection-disconnect-requested(key);
                                    }
                                }

                                Rectangle {
                                    height: root.sidebar-details-bottom-padding;
                                    background: transparent;
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 30px;
            background: #ffffff;
            border-color: #dfe4ec;
            border-width: 1px;

            TouchArea {
                clicked => {
                    root.clear-active-inputs();
                    root.selection-cleared();
                }
            }

            Text {
                x: 12px;
                width: parent.width - 24px;
                height: parent.height;
                text: root.status-text
                    + "   |   " + root.summary-throughput
                    + "   |   Global " + root.summary-global-limit
                    + "   |   Limited " + root.summary-process-limits
                    + "   Blocked " + root.summary-blocked
                    + "   Adaptive " + root.summary-adaptive;
                color: root.running ? #167454 : #596579;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-alignment: left;
                overflow: elide;
            }
        }
        }
    }

    if (root.settings-open) : Rectangle {
        width: 100%;
        height: 100%;
        z: 1000;

        dismiss-hit := TouchArea {
            clicked => {
                root.settings-open = false;
            }
        }

        SettingsDropdown {
            x: root.settings-menu-x;
            y: 36px;
            z: 1;
            speed-unit-bits: root.speed-unit-bits;
            ipv6-enabled: root.ipv6-enabled;
            speed-unit-bits-changed(bits) => {
                root.clear-active-inputs();
                root.speed-unit-bits-changed(bits);
            }
            ipv6-enabled-changed(enabled) => {
                root.clear-active-inputs();
                root.ipv6-enabled-changed(enabled);
            }
            close-requested => {
                root.settings-open = false;
            }
        }
    }
}
