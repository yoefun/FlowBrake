component ChromeIcon inherits Rectangle {
    in property <string> kind;
    in property <bool> restore;
    in property <color> line-color;
    background: transparent;

    if (root.kind == "minimize") : Rectangle {
        width: 12px;
        height: 2px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2 + 5px;
        background: root.line-color;
        border-radius: 1px;
    }

    if (root.kind == "maximize" && !root.restore) : Rectangle {
        width: 11px;
        height: 10px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        background: transparent;
        border-color: root.line-color;
        border-width: 1px;
    }

    if (root.kind == "maximize" && root.restore) : Rectangle {
        width: 11px;
        height: 10px;
        x: (root.width - self.width) / 2 - 2px;
        y: (root.height - self.height) / 2 + 2px;
        background: transparent;
        border-color: root.line-color;
        border-width: 1px;
    }

    if (root.kind == "maximize" && root.restore) : Rectangle {
        width: 11px;
        height: 10px;
        x: (root.width - self.width) / 2 + 2px;
        y: (root.height - self.height) / 2 - 2px;
        background: transparent;
        border-color: root.line-color;
        border-width: 1px;
    }

    if (root.kind == "close") : Text {
        text: "X";
        width: root.width;
        height: root.height;
        color: root.line-color;
        font-size: 14px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    if (root.kind == "settings") : Path {
        width: 14px;
        height: 14px;
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        stroke: root.line-color;
        stroke-width: 1.2px;
        commands: "M 7 1.5 A 2.2 2.2 0 1 1 6.99 1.5 M 7 3.2 L 7 4.4 M 7 9.6 L 7 10.8 M 3.2 7 L 4.4 7 M 9.6 7 L 10.8 7 M 4.5 4.5 L 5.3 5.3 M 8.7 8.7 L 9.5 9.5 M 4.5 9.5 L 5.3 8.7 M 8.7 5.3 L 9.5 4.5";
    }
}

component SettingsMenuItem inherits Rectangle {
    in property <string> text;
    in property <bool> selected;
    callback activate();
    height: 32px;
    background: hit.has-hover ? #edf2f7 : transparent;

    hit := TouchArea {
        clicked => {
            root.activate();
        }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;

        Rectangle {
            width: 16px;
            height: 16px;
            y: (parent.height - self.height) / 2;
            border-color: root.selected ? #315f90 : #9aa8b8;
            border-width: 1px;
            border-radius: 8px;
            background: root.selected ? #315f90 : transparent;

            if (root.selected) : Rectangle {
                width: 6px;
                height: 6px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: #ffffff;
                border-radius: 3px;
            }
        }

        Text {
            text: root.text;
            color: #24303f;
            font-size: 12px;
            font-weight: root.selected ? 600 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

export component SettingsDropdown inherits Rectangle {
    in property <bool> speed-unit-bits;
    callback speed-unit-bits-changed(bool);
    callback close-requested();

    width: 220px;
    height: menu.preferred-height;
    background: #ffffff;
    border-color: #d7e0eb;
    border-width: 1px;
    border-radius: 6px;
    drop-shadow-blur: 12px;
    drop-shadow-color: #00000025;
    clip: true;

    menu := VerticalLayout {
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 0px;

        HorizontalLayout {
            height: 18px;
            padding-left: 12px;
            padding-right: 12px;

            Text {
                text: "Speed units";
                color: #65758b;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        SettingsMenuItem {
            text: "ISP units (Mb/s)";
            selected: root.speed-unit-bits;
            activate => {
                root.speed-unit-bits-changed(true);
                root.close-requested();
            }
        }

        SettingsMenuItem {
            text: "Standard units (KB/s)";
            selected: !root.speed-unit-bits;
            activate => {
                root.speed-unit-bits-changed(false);
                root.close-requested();
            }
        }
    }
}

export component SettingsButton inherits Rectangle {
    callback clicked();

    width: 40px;
    height: 36px;
    background: !hit.has-hover ? transparent : (hit.pressed ? #d5dde8 : #edf2f7);

    hit := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    ChromeIcon {
        width: 18px;
        height: 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        kind: "settings";
        line-color: #28313d;
    }
}

export component WindowControlButton inherits Rectangle {
    in property <string> kind;
    in property <bool> restore: false;
    callback clicked();

    width: 46px;
    height: 36px;
    background: !hit.has-hover ? transparent
        : root.kind == "close"
            ? (hit.pressed ? #a82424 : #d83b3b)
            : (hit.pressed ? #d5dde8 : #edf2f7);

    property <color> icon-color: root.kind == "close" && hit.has-hover ? #ffffff : #28313d;

    hit := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    ChromeIcon {
        width: 18px;
        height: 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        kind: root.kind;
        restore: root.restore;
        line-color: root.icon-color;
    }
}

export component TitleBar inherits Rectangle {
    in property <string> title;
    in property <bool> maximized;
    in property <bool> speed-unit-bits;
    in-out property <bool> settings-open: false;
    callback drag-requested();
    callback maximize-toggle-requested();
    callback minimize-requested();
    callback close-requested();
    callback speed-unit-bits-changed(bool);

    height: 36px;
    background: #f9fbfe;
    border-color: #dfe6ef;
    border-width: 1px;

    HorizontalLayout {
        padding-left: 12px;
        spacing: 0px;

        Rectangle {
            width: 18px;
            height: 18px;
            y: (parent.height - self.height) / 2;
            background: #245b85;
            border-radius: 4px;

            Text {
                text: "F";
                width: parent.width;
                height: parent.height;
                color: white;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.title;
            width: 150px;
            height: parent.height;
            color: #24303f;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-alignment: left;
            overflow: elide;
        }

        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;

            drag-hit := TouchArea {
                moved => {
                    if (self.pressed) {
                        root.drag-requested();
                    }
                }
                double-clicked => {
                    root.maximize-toggle-requested();
                }
            }
        }

        SettingsButton {
            clicked => {
                root.settings-open = !root.settings-open;
            }
        }

        WindowControlButton {
            kind: "minimize";
            clicked => {
                root.minimize-requested();
            }
        }

        WindowControlButton {
            kind: "maximize";
            restore: root.maximized;
            clicked => {
                root.maximize-toggle-requested();
            }
        }

        WindowControlButton {
            kind: "close";
            clicked => {
                root.close-requested();
            }
        }
    }
}
